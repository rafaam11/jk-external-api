---
import { catalog } from "@jk-external-api/catalog";
import BaseLayout from "../../layouts/BaseLayout.astro";
import RegistryTable from "../../components/RegistryTable";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<BaseLayout title="정보원 기록">
  <header class="page-header"><p class="eyebrow">Source register / 14</p><h1>정보원 기록</h1><p>운영기관, 인증, 갱신 주기와 형식을 한 화면에서 비교합니다.</p></header>
  <RegistryTable client:load kind="source" catalog={catalog} base={base} />
</BaseLayout>
