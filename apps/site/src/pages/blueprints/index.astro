---
import { catalog } from "@jk-external-api/catalog";
import BaseLayout from "../../layouts/BaseLayout.astro";
import RegistryTable from "../../components/RegistryTable";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<BaseLayout title="프로젝트 청사진">
  <header class="page-header"><p class="eyebrow">Blueprint register / 06</p><h1>생활 문제 청사진</h1><p>해결 문제, 정보원 조합과 주요 출력을 빠르게 확인합니다.</p></header>
  <RegistryTable client:load kind="blueprint" catalog={catalog} base={base} />
</BaseLayout>
