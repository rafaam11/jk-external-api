---
import { catalog } from "@jk-external-api/catalog";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CopyCode from "../../components/CopyCode";
import { formatDomain } from "../../lib/labels.js";
export function getStaticPaths() { return catalog.blueprints.map((blueprint) => ({ params: { id: blueprint.id }, props: { blueprint } })); }
const { blueprint } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const sources = catalog.sources.filter((source) => blueprint.sourceIds.includes(source.id));
---
<BaseLayout title={blueprint.name} description={blueprint.problem}>
  <article class="detail-page"><header class="detail-header"><div><a class="back-link" href={`${base}/blueprints/`}>← 청사진 목록</a><p class="eyebrow">PROJECT BLUEPRINT</p><h1>{blueprint.name}</h1><p>{blueprint.problem}</p></div><div class="detail-stamp"><span>READ-ONLY</span><strong>{String(sources.length).padStart(2, "0")} SOURCES</strong><small>서버 비밀키 원칙</small></div></header>
  <div class="io-grid"><section><h2>사용자</h2><ul>{blueprint.users.map((item) => <li>{item}</li>)}</ul></section><section><h2>입력</h2><ul>{blueprint.inputs.map((item) => <li>{item}</li>)}</ul></section><section><h2>출력</h2><ul>{blueprint.outputs.map((item) => <li>{item}</li>)}</ul></section></div>
  <section class="flow-section"><h2>데이터 흐름</h2><ol>{blueprint.flow.map((step, index) => <li><span>{String(index + 1).padStart(2, "0")}</span><p>{step}</p></li>)}</ol></section>
  <details class="detail-disclosure source-combination"><summary>조합 정보원 <span>{sources.length}개</span></summary>{sources.map((source) => <a href={`${base}/sources/${source.id}/`}><span>{formatDomain(source.domains[0] ?? "")}</span><strong>{source.name}</strong><small>{source.data[0]?.fields.slice(0, 3).join(" · ")}</small></a>)}</details>
  <div class="detail-grid"><section><h2>MVP 단계</h2><ol class="plain-list">{blueprint.mvpSteps.map((item) => <li>{item}</li>)}</ol><h3>권장 스택</h3><ul class="tag-list">{blueprint.stack.map((item) => <li>{item}</li>)}</ul></section><details class="detail-disclosure risk-disclosure"><summary>위험과 fallback</summary><h3>위험</h3><ul>{blueprint.risks.map((item) => <li>{item}</li>)}</ul><h3>개인정보</h3><ul>{blueprint.privacy.map((item) => <li>{item}</li>)}</ul><h3>실패 시</h3><ul>{blueprint.fallback.map((item) => <li>{item}</li>)}</ul></details></div>
  <details class="detail-disclosure code-examples"><summary>최소 서버 호출 예제</summary><p>비밀키는 브라우저 코드가 아니라 서버 환경변수에서만 읽습니다.</p><CopyCode client:idle code={blueprint.examples.node} label="Node.js" /><CopyCode client:idle code={blueprint.examples.python} label="Python" /></details>
  </article>
</BaseLayout>
