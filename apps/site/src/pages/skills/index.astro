---
import { catalog } from "@jk-external-api/catalog";
import BaseLayout from "../../layouts/BaseLayout.astro";
import RegistryTable from "../../components/RegistryTable";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<BaseLayout title="k-skill 색인">
  <header class="page-header"><p class="eyebrow">Upstream snapshot / {catalog.skills.length}</p><h1>k-skill 전체 색인</h1><p>활성 문서와 legacy 기록의 실행 환경, 인증 단서와 정보원 연결을 조회합니다.</p></header>
  <RegistryTable client:load kind="skill" catalog={catalog} base={base} />
</BaseLayout>
