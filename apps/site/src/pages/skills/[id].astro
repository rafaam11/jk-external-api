---
import { catalog } from "@k-source-atlas/catalog";
import BaseLayout from "../../layouts/BaseLayout.astro";
export function getStaticPaths() { return catalog.skills.map((skill) => ({ params: { id: skill.id }, props: { skill } })); }
const { skill } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const sources = catalog.sources.filter((source) => skill.sourceIds.includes(source.id));
const technologies = catalog.technologies.filter((technology) => skill.technologyIds.includes(technology.id));
---
<BaseLayout title={skill.name} description={skill.description}>
  <article class="detail-page narrow"><header class="detail-header"><div><a class="back-link" href={`${base}/skills/`}>← k-skill 색인</a><p class="eyebrow">{skill.category}</p><h1>{skill.name}</h1><p>{skill.description}</p></div><div class="detail-stamp"><span>UPSTREAM</span><strong>{skill.upstreamPath}</strong><small>생성 스냅샷</small></div></header>
  <div class="detail-grid"><section><h2>실행 환경</h2><ul class="tag-list">{skill.runtimes.map((runtime) => <li>{runtime}</li>)}</ul></section><section><h2>인증 단서</h2>{skill.auth.length ? <ul class="tag-list">{skill.auth.map((auth) => <li>{auth}</li>)}</ul> : <p>문서에서 별도 환경변수 단서를 찾지 못했습니다.</p>}</section></div>
  <section class="relation-section"><h2>연결 기록</h2><div class="relation-columns"><div><h3>정보원</h3>{sources.length ? sources.map((source) => <a href={`${base}/sources/${source.id}/`}>{source.name}</a>) : <p>수동 보정 관계가 없습니다.</p>}</div><div><h3>기술</h3>{technologies.length ? technologies.map((technology) => <a href={`${base}/technologies/#${technology.id}`}>{technology.name}</a>) : <p>수동 보정 관계가 없습니다.</p>}</div><div><h3>원문</h3><a href={skill.upstreamUrl}>GitHub의 SKILL.md ↗</a></div></div></section></article>
</BaseLayout>
