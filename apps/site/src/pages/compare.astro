---
import { catalog } from "@k-source-atlas/catalog";
import CompareTable from "../components/CompareTable";
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<BaseLayout title="정보원 비교">
  <header class="page-header"><p class="eyebrow">Comparison desk / max 04</p><h1>정보원 비교</h1><p>인증, 비용, 형식, 갱신, 지역, 미리보기와 기술을 같은 표에서 확인합니다.</p></header>
  <CompareTable client:load sources={catalog.sources} technologies={catalog.technologies} initialIds={[]} base={base} />
</BaseLayout>
