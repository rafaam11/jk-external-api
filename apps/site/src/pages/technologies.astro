---
import { catalog } from "@jk-external-api/catalog";
import BaseLayout from "../layouts/BaseLayout.astro";
import RegistryTable from "../components/RegistryTable";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<BaseLayout title="기술 연결표">
  <header class="page-header"><p class="eyebrow">Technology register / {catalog.technologies.length}</p><h1>기술 연결표</h1><p>프로토콜과 형식이 연결하는 정보원·k-skill 수를 조회합니다.</p></header>
  <RegistryTable client:load kind="technology" catalog={catalog} base={base} />
</BaseLayout>
